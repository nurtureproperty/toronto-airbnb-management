# GoHighLevel Private Integration Token
GHL_API_TOKEN=pit-your-token-here

# Anthropic API Key (for Claude)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# GHL Calendar ID for appointment booking (GHL → Calendars → select calendar → ID in URL or Settings)
# Optional: if not set, bot directs leads to nurturestays.ca/contact instead of booking directly
GHL_CALENDAR_ID=your-calendar-id-here

# Slack notifications for urgent FB leads
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_CHANNEL_ID=your-channel-id

# Owner's GHL contact ID for SMS notifications when leads want a callback
# Optional: if not set, only Slack notifications are sent
OWNER_PHONE=your-ghl-contact-id

# Server Port (optional, defaults to 3000)
PORT=3000
