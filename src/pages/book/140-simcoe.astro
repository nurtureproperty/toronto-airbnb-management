<script is:inline define:vars={{ photos }}>
  // Photo Gallery
  let currentPhotoIndex = 0;
  const galleryPhotos = photos;

  window.openGallery = function(index) {
    currentPhotoIndex = index;
    const modal = document.getElementById('galleryModal');
    modal.classList.add('active');
    updateGalleryImage();
    document.body.style.overflow = 'hidden';
  }

  window.closeGallery = function() {
    document.getElementById('galleryModal').classList.remove('active');
    document.body.style.overflow = '';
  }

  window.nextPhoto = function() {
    currentPhotoIndex = (currentPhotoIndex + 1) % galleryPhotos.length;
    updateGalleryImage();
  }

  window.prevPhoto = function() {
    currentPhotoIndex = (currentPhotoIndex - 1 + galleryPhotos.length) % galleryPhotos.length;
    updateGalleryImage();
  }

  function updateGalleryImage() {
    const photo = galleryPhotos[currentPhotoIndex];
    document.getElementById('galleryImage').src = photo.url;
    document.getElementById('galleryImage').alt = photo.caption;
    document.getElementById('galleryCaption').textContent = photo.caption;
    document.getElementById('galleryCounter').textContent = (currentPhotoIndex + 1) + ' / ' + galleryPhotos.length;
  }

  // Keyboard navigation
  document.addEventListener('keydown', function(e) {
    const modal = document.getElementById('galleryModal');
    if (!modal.classList.contains('active')) return;
    if (e.key === 'Escape') closeGallery();
    if (e.key === 'ArrowRight') nextPhoto();
    if (e.key === 'ArrowLeft') prevPhoto();
  });
</script>

<script is:inline define:vars={{ calendarData }}>
  // Calendar state
  const cal = calendarData;
  const calMap = {};
  cal.forEach(d => { calMap[d.d] = d; });

  let selectedCheckin = null;
  let selectedCheckout = null;
  let selectingFor = 'checkin';
  let currentMonth = new Date().getMonth();
  let currentYear = new Date().getFullYear();
  const CLEANING_FEE = 9900; // $99 cleaning fee in cents (from Hospitable)
  // Empirical multiplier on (nightly + cleaning) to match Airbnb's guest total
  // Covers: Airbnb service fee (~14%) + HST (13%) + MAT (8.5% Toronto)
  const AIRBNB_MULTIPLIER_WITH_MAT = 1.47;
  // For stays 28+ nights: no MAT charged
  const AIRBNB_MULTIPLIER_NO_MAT = 1.37;
  // Direct price = Airbnb price - Airbnb guest service fee (~14%) + our margin (7%)
  // Effectively: base * (airbnb_multiplier - 0.14 + 0.07)
  const AIRBNB_GUEST_FEE = 0.155; // Airbnb charges guests 15.5% service fee
  const OUR_MARGIN = 0.07;

  const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];

  window.showCalendar = function(type) {
    selectingFor = type;
    document.getElementById('calendarDropdown').classList.add('open');
    document.getElementById('checkinField').classList.toggle('active', type === 'checkin');
    document.getElementById('checkoutField').classList.toggle('active', type === 'checkout');
    renderCalendar();
  }

  window.changeMonth = function(dir) {
    currentMonth += dir;
    if (currentMonth > 11) { currentMonth = 0; currentYear++; }
    if (currentMonth < 0) { currentMonth = 11; currentYear--; }
    renderCalendar();
  }

  window.clearDates = function() {
    selectedCheckin = null;
    selectedCheckout = null;
    document.getElementById('checkinDisplay').textContent = 'Add date';
    document.getElementById('checkoutDisplay').textContent = 'Add date';
    document.getElementById('priceBreakdown').style.display = 'none';
    document.getElementById('bookingForm').style.display = 'none';
    document.getElementById('checkAvailBtn').style.display = '';
    selectingFor = 'checkin';
    renderCalendar();
  }

  window.selectDate = function(dateStr) {
    skipNextClose = true;
    if (selectingFor === 'checkin') {
      selectedCheckin = dateStr;
      selectedCheckout = null;
      document.getElementById('checkinDisplay').textContent = formatDateShort(dateStr);
      document.getElementById('checkoutDisplay').textContent = 'Add date';
      selectingFor = 'checkout';
      document.getElementById('checkinField').classList.remove('active');
      document.getElementById('checkoutField').classList.add('active');
    } else {
      if (dateStr <= selectedCheckin) {
        selectedCheckin = dateStr;
        selectedCheckout = null;
        document.getElementById('checkinDisplay').textContent = formatDateShort(dateStr);
        document.getElementById('checkoutDisplay').textContent = 'Add date';
        selectingFor = 'checkout';
      } else {
        // Check if any booked day falls between checkin and checkout
        let hasBlockedDay = false;
        const ci = new Date(selectedCheckin + 'T00:00:00');
        const co = new Date(dateStr + 'T00:00:00');
        for (let d = new Date(ci); d < co; d.setDate(d.getDate() + 1)) {
          const ds = d.toISOString().split('T')[0];
          if (calMap[ds] && !calMap[ds].a) {
            hasBlockedDay = true;
            break;
          }
        }
        if (hasBlockedDay) {
          return; // Can't select across booked dates
        }

        selectedCheckout = dateStr;
        document.getElementById('checkoutDisplay').textContent = formatDateShort(dateStr);
        updatePriceBreakdown();
        setTimeout(function() {
          document.getElementById('calendarDropdown').classList.remove('open');
        }, 300);
      }
    }
    renderCalendar();
  }

  function updatePriceBreakdown() {
    if (!selectedCheckin || !selectedCheckout) return;

    const ci = new Date(selectedCheckin + 'T00:00:00');
    const co = new Date(selectedCheckout + 'T00:00:00');
    const nights = Math.round((co - ci) / (1000 * 60 * 60 * 24));

    // Sum actual prices per night
    let totalNightly = 0;
    for (let d = new Date(ci); d < co; d.setDate(d.getDate() + 1)) {
      const ds = d.toISOString().split('T')[0];
      if (calMap[ds]) totalNightly += calMap[ds].p;
    }

    const multiplier = nights >= 28 ? AIRBNB_MULTIPLIER_NO_MAT : AIRBNB_MULTIPLIER_WITH_MAT;
    const base = totalNightly + CLEANING_FEE;
    const airbnbTotal = Math.round(base * multiplier);
    const airbnbGuestFee = Math.round(base * AIRBNB_GUEST_FEE);
    const ourMargin = Math.round(base * OUR_MARGIN);
    const directTotal = airbnbTotal - airbnbGuestFee + ourMargin;
    const discount = airbnbTotal - directTotal;

    document.getElementById('airbnbTotal').textContent = '$' + (airbnbTotal / 100).toFixed(0);
    document.getElementById('discountAmount').textContent = '-$' + (discount / 100).toFixed(0);
    document.getElementById('totalPrice').textContent = '$' + (directTotal / 100).toFixed(0);
    document.getElementById('priceBreakdown').style.display = 'block';
    document.getElementById('bookingForm').style.display = 'flex';
    document.getElementById('checkAvailBtn').style.display = 'none';
  }

  function renderCalendar() {
    document.getElementById('calMonth').textContent = monthNames[currentMonth] + ' ' + currentYear;

    const firstDay = new Date(currentYear, currentMonth, 1).getDay();
    const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();
    const today = new Date().toISOString().split('T')[0];

    let html = '';
    // Empty cells before first day
    for (let i = 0; i < firstDay; i++) {
      html += '<div class="cal-day empty"></div>';
    }

    for (let day = 1; day <= daysInMonth; day++) {
      const dateStr = currentYear + '-' + String(currentMonth + 1).padStart(2, '0') + '-' + String(day).padStart(2, '0');
      const info = calMap[dateStr];
      const isPast = dateStr < today;
      const isAvailable = info && info.a && !isPast;
      const isBooked = info && !info.a;

      let cls = 'cal-day';
      if (isPast) cls += ' past';
      else if (isBooked) cls += ' booked';
      else if (isAvailable) cls += ' available';

      // Highlight selected range
      if (dateStr === selectedCheckin) cls += ' selected-start';
      if (dateStr === selectedCheckout) cls += ' selected-end';
      if (selectedCheckin && selectedCheckout && dateStr > selectedCheckin && dateStr < selectedCheckout) cls += ' in-range';

      // When selecting checkout, the first booked date after checkin is a valid
      // checkout (guest leaves morning before next guest arrives)
      let isValidCheckout = false;
      if (selectingFor === 'checkout' && selectedCheckin && isBooked && !isPast && dateStr > selectedCheckin) {
        // Check that all days between checkin and this date are available
        let allClear = true;
        const ci = new Date(selectedCheckin + 'T00:00:00');
        const co = new Date(dateStr + 'T00:00:00');
        for (let dd = new Date(ci); dd < co; dd.setDate(dd.getDate() + 1)) {
          const ds = dd.toISOString().split('T')[0];
          if (calMap[ds] && !calMap[ds].a) { allClear = false; break; }
        }
        if (allClear) isValidCheckout = true;
      }

      if (isValidCheckout) cls += ' checkout-ok';

      const clickable = (isAvailable || isValidCheckout) ? ' onclick="selectDate(\'' + dateStr + '\')"' : '';

      html += '<div class="' + cls + '"' + clickable + '>';
      html += '<span class="day-num">' + day + '</span>';
      html += '</div>';
    }

    document.getElementById('calDays').innerHTML = html;
  }

  function formatDateShort(dateStr) {
    const d = new Date(dateStr + 'T00:00:00');
    return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  }

  // Close calendar when clicking outside
  let skipNextClose = false;
  document.addEventListener('click', function(e) {
    if (skipNextClose) { skipNextClose = false; return; }
    const dropdown = document.getElementById('calendarDropdown');
    const selector = document.getElementById('dateSelector');
    if (!dropdown.contains(e.target) && !selector.contains(e.target) && !e.target.closest('#checkAvailBtn')) {
      dropdown.classList.remove('open');
    }
  });

  // Booking form submission
  const form = document.getElementById('bookingForm');
  const successMsg = document.getElementById('bookingSuccess');

  form?.addEventListener('submit', function(e) {
    e.preventDefault();
    const formData = new FormData(form);
    const data = Object.fromEntries(formData);
    const guests = document.getElementById('guestCount').value;

    const subject = encodeURIComponent('Direct Booking Request: 140 Simcoe #303');
    const body = encodeURIComponent(
      'New direct booking request:\n\n' +
      'Name: ' + data.name + '\n' +
      'Email: ' + data.email + '\n' +
      'Phone: ' + data.phone + '\n' +
      'Check-in: ' + selectedCheckin + '\n' +
      'Check-out: ' + selectedCheckout + '\n' +
      'Guests: ' + guests + '\n' +
      'Message: ' + (data.message || 'None')
    );

    window.location.href = 'mailto:hello@nurturestays.ca?subject=' + subject + '&body=' + body;

    form.style.display = 'none';
    document.getElementById('priceBreakdown').style.display = 'none';
    successMsg.style.display = 'flex';
  });
</script>

