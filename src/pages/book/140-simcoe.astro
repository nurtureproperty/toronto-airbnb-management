const schema = {
  "@context": "https://schema.org",
  "@type": "LodgingBusiness",
  "name": property.name,
  "description": pageDescription,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "140 Simcoe St #303",
    "addressLocality": "Toronto",
    "addressRegion": "ON",
    "postalCode": "M5H 4E9",
    "addressCountry": "CA"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": property.coordinates.lat,
    "longitude": property.coordinates.lng
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": property.rating,
    "reviewCount": property.reviewCount
  },
  "amenityFeature": amenities.map(a => ({ "@type": "LocationFeatureSpecification", "name": a.label })),
  "checkinTime": "16:00",
  "checkoutTime": "11:00"
};
---

<Layout title={pageTitle} description={pageDescription} schema={schema}>
  <!-- Direct Booking Banner -->
  <div class="direct-banner">
    <div class="container">
      Book direct to save on your stay and support local
    </div>
  </div>

  <!-- Title (above photos like Airbnb) -->
  <section class="property-title">
    <div class="container">
      <h1>{property.name}</h1>
    </div>
  </section>

  <!-- Photo Gallery -->
  <section class="property-hero">
    <div class="photo-grid">
      <div class="photo-main">
        <img src={photos[0].url} alt={photos[0].caption} loading="eager" onclick="openGallery(0)" />
      </div>
      <div class="photo-small">
        <img src={photos[1].url} alt={photos[1].caption} loading="eager" onclick="openGallery(1)" />
      </div>
      <div class="photo-small">
        <img src={photos[2].url} alt={photos[2].caption} loading="eager" onclick="openGallery(2)" />
      </div>
      <div class="photo-small">
        <img src={photos[3].url} alt={photos[3].caption} loading="eager" onclick="openGallery(3)" />
      </div>
      <div class="photo-small photo-last">
        <img src={photos[4].url} alt={photos[4].caption} loading="eager" onclick="openGallery(4)" />
        <button class="show-all-btn" onclick="openGallery(0)">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><circle cx="3" cy="3" r="1.5"/><circle cx="8" cy="3" r="1.5"/><circle cx="13" cy="3" r="1.5"/><circle cx="3" cy="8" r="1.5"/><circle cx="8" cy="8" r="1.5"/><circle cx="13" cy="8" r="1.5"/><circle cx="3" cy="13" r="1.5"/><circle cx="8" cy="13" r="1.5"/><circle cx="13" cy="13" r="1.5"/></svg>
          Show all photos
        </button>
      </div>
    </div>
  </section>

  <!-- Fullscreen Gallery Modal -->
  <div class="gallery-modal" id="galleryModal">
    <button class="gallery-close" onclick="closeGallery()">✕</button>
    <button class="gallery-nav gallery-prev" onclick="prevPhoto()">‹</button>
    <button class="gallery-nav gallery-next" onclick="nextPhoto()">›</button>
    <div class="gallery-content">
      <img id="galleryImage" src="" alt="" />
      <p class="gallery-caption" id="galleryCaption"></p>
      <p class="gallery-counter" id="galleryCounter"></p>
    </div>
  </div>

  <!-- Main Content -->
  <section class="property-content">
    <div class="container">
      <div class="content-grid">
        <!-- Left Column: Details -->
        <div class="details-column">
          <!-- Property type + stats -->
          <div class="property-header">
            <h2 class="property-type">Entire condo in Toronto, Canada</h2>
            <p class="property-stats">{property.guests} guests · {property.bedrooms} bedroom · {property.beds} beds · {property.bathrooms} bath</p>
          </div>

          <!-- Guest Favourite Badge -->
          <div class="guest-favourite">
            <div class="gf-left">
              <p class="gf-title">Guest favourite</p>
              <p class="gf-sub">One of the most loved homes on Airbnb, according to guests</p>
            </div>
            <div class="gf-right">
              <span class="gf-rating">{property.rating}</span>
              <span class="gf-stars">★★★★★</span>
              <span class="gf-count">{property.reviewCount} Reviews</span>
            </div>
          </div>

          <!-- Hosted By -->
          <div class="hosted-by">
            <img src="/images/logo.webp" alt="Nurture" class="host-avatar" />
            <div>
              <p class="host-name">Hosted by Jeffrey</p>
              <p class="host-detail">Superhost · 5 months hosting</p>
            </div>
          </div>

          <!-- Highlights -->
          <div class="section-block">
            <div class="highlight-item">
              <svg class="highlight-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4M10 17l5-5-5-5M13 12H3"/></svg>
              <div>
                <p class="highlight-title">Exceptional check-in experience</p>
                <p class="highlight-desc">Recent guests gave the check-in process a 5-star rating.</p>
              </div>
            </div>
            <div class="highlight-item">
              <svg class="highlight-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <div>
                <p class="highlight-title">Vibrant neighbourhood</p>
                <p class="highlight-desc">Guests say this area is walkable with lots to explore, especially for dining out.</p>
              </div>
            </div>
            <div class="highlight-item">
              <svg class="highlight-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
              <div>
                <p class="highlight-title">Dedicated workspace</p>
                <p class="highlight-desc">A private room with a desk, dual monitors, and fast Wi-Fi.</p>
              </div>
            </div>
          </div>

          <!-- Description -->
          <div class="section-block">
            <p>Stay in the heart of downtown in this bright 1BR condo made for comfort and convenience. Features a queen bed, sofa bed, full bath with tub, fast Wi-Fi, smart TV, in-unit laundry, and workstation with second monitor, perfect for working from home.</p>
            <p>Enjoy your morning coffee on the balcony or unwind after a day out. Access building perks like a gym, rooftop deck, lounge, and concierge. Steps from shops, restaurants, and entertainment, everything you need for a relaxing city stay.</p>
          </div>

          <!-- Where you'll sleep -->
          <div class="section-block">
            <h2>Where you'll sleep</h2>
            <div class="sleeping-grid">
              {sleepingArrangements.map(s => (
                <div class="sleeping-card">
                  <p class="sleeping-room">{s.room}</p>
                  <p class="sleeping-bed">1 {s.bed.toLowerCase()}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- What this place offers -->
          <div class="section-block">
            <h2>What this place offers</h2>
            <div class="amenities-grid">
              {amenities.slice(0, 10).map(a => (
                <div class="amenity-item">
                  <span>{a.label}</span>
                </div>
              ))}
            </div>
            <button class="show-all-amenities">Show all {amenities.length} amenities</button>
          </div>

          <!-- Where you'll be -->
          <div class="section-block">
            <h2>Where you'll be</h2>
