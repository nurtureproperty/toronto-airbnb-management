---
import Layout from '../layouts/Layout.astro';

const neighborhoods = [
  { icon: '🌊', name: 'Downtown Waterfront', description: 'Dunlop Street, the marina, Centennial Beach, and Meridian Place are all walkable. Guests love the summer patios, live music, and quick access to Kempenfelt Bay. Peak rates June through September.', revenue: '$2,800-$4,200/month' },
  { icon: '🚉', name: 'Allandale', description: 'South end neighbourhood near Allandale Waterfront GO Station. One hour train to Toronto makes it popular with commuters and weekend visitors who want waterfront views without downtown prices.', revenue: '$2,400-$3,400/month' },
  { icon: '🏥', name: 'Near Royal Victoria Hospital', description: 'Quiet streets within a short drive of RVH. Steady demand from traveling nurses on 13 week contracts, locum doctors, and families of patients. Mid-term stays dominate year round.', revenue: '$2,600-$3,800/month' },
  { icon: '🏘️', name: 'Painswick', description: 'South Barrie family neighbourhood with newer builds and big driveways. Popular with relocating families and larger groups visiting for weddings or sports tournaments.', revenue: '$2,500-$3,600/month' },
  { icon: '🎓', name: 'Near Georgian College', description: 'North end area close to Georgian College and the Barrie North GO line. Strong demand from visiting parents, prospective students, and conference attendees throughout the school year.', revenue: '$2,300-$3,300/month' },
  { icon: '⛵', name: 'Lake Simcoe Shoreline', description: 'Properties along the northeast shore toward Shanty Bay and Big Bay Point. Cottage feel with ice fishing in winter and boating all summer. Highest nightly rates in peak season.', revenue: '$3,000-$4,500/month' }
];

const services = [
  'Dynamic Pricing & Revenue Optimization',
  'Guest Communication & Support',
  'Professional Photography',
  'Cleaning & Turnover Coordination',
  'Maintenance & Repairs',
  'Guest Screening & Verification',
  'Supply Restocking (No Markup)',
  'Multi-Platform Distribution (Airbnb, VRBO, Booking.com)',
  'Transparent Revenue Reporting'
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Barrie Airbnb Management",
  "description": "Barrie Airbnb management for Downtown Waterfront, Allandale, RVH, and Lake Simcoe properties. Dynamic pricing and guest screening. 18% fees.",
  "url": "https://www.nurturestays.ca/barrie-airbnb-management",
  "areaServed": {
    "@type": "City",
    "name": "Barrie",
    "containedInPlace": { "@type": "AdministrativeArea", "name": "Ontario" }
  },
  "provider": {
    "@type": "LocalBusiness",
    "name": "Nurture Airbnb Property Management"
  }
};
---

<Layout title="Barrie Airbnb Management | 18%" description="Barrie Airbnb management at 18%. No STR bylaw, investment properties allowed, 503 active listings. We handle everything. Free estimate." schema={serviceSchema}>
  <section class="hero">
    <div class="container">
      <h1><span class="highlight">Barrie Airbnb Management</span></h1>
      <p class="hero-subtitle">Expert property management on Lake Simcoe. No STR bylaw, investment properties welcome.</p>

      <div class="hero-stats">
        <div class="stat">
          <div class="stat-number">No License</div>
          <div class="stat-label">Required in Barrie</div>
        </div>
        <div class="stat">
          <div class="stat-number">503</div>
          <div class="stat-label">Active STRs in Barrie</div>
        </div>
        <div class="stat">
          <div class="stat-number">18%</div>
          <div class="stat-label">Management Fee</div>
        </div>
      </div>

      <a href="/contact" class="btn btn-primary btn-large">See How Much Your Barrie Property Can Earn</a>
    </div>
  </section>

  <section class="section neighborhoods">
    <div class="container">
      <div class="section-header">
        <h2>Barrie Areas We Serve</h2>
        <p>From the waterfront to the lakeshore and beyond</p>
      </div>
      <div class="neighborhoods-grid">
        {neighborhoods.map(n => (
          <div class="neighborhood-card">
            <h3>{n.icon} {n.name}</h3>
            <p>{n.description}</p>
            <div class="avg-revenue">Avg Revenue: {n.revenue}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bylaws-section">
    <div class="container">
      <div class="section-header">
        <h2>Barrie Short-Term Rental Rules</h2>
        <p>What Barrie property owners need to know</p>
      </div>
      <div class="bylaws-content">
        <div class="bylaws-grid">
          <div class="bylaw-card">
            <h3>No STR License Required</h3>
            <p>Barrie does not require a short-term rental license or registration. You can list on Airbnb, VRBO, and Booking.com without a municipal permit. See our <a href="/blog/barrie-airbnb-short-term-rental-rules-2026">full Barrie STR rules guide</a> for details.</p>
          </div>
          <div class="bylaw-card">
            <h3>No Principal Residence Rule</h3>
            <p>Unlike <a href="/full-airbnb-management-toronto">Toronto</a>, Mississauga, and most GTA cities, Barrie does not restrict STRs to principal residences. Investment properties, second homes, and cottages are all eligible.</p>
          </div>
          <div class="bylaw-card">
            <h3>No Night Cap</h3>
            <p>There is no annual limit on the number of nights you can rent. You can operate 365 days a year, maximizing your revenue potential year round.</p>
          </div>
          <div class="bylaw-card">
            <h3>Regulations May Be Coming</h3>
            <p>City council passed Motion 24-G-033 in 2024 to investigate STR regulation. We expect proposed rules within 12 to 24 months. Getting established now means you operate while new entrants face future licensing delays.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section why-section">
    <div class="container">
      <div class="why-content">
        <h2>The Barrie Advantage</h2>
        <p>Barrie is one of the few mid sized Ontario cities still operating without short-term rental regulation. While Toronto, Mississauga, Burlington, Milton, and most other GTA cities have introduced licensing, Barrie remains wide open for investors.</p>
        <p>Year round demand drivers make Barrie strong in every season. Royal Victoria Hospital brings travel nurses on 13 week contracts. Georgian College generates parent and conference traffic. Summer brings beach tourists and cottage country travelers. Winter brings ice fishing and ski day trippers heading to Horseshoe Resort and Mount St. Louis. Our <a href="/services/airbnb-dynamic-pricing" style="color: #C9A961;">dynamic pricing</a> captures peak demand across every season.</p>
      </div>
      <div class="airport-stats">
        <div class="airport-stat">
          <div class="number">150K+</div>
          <div class="label">Population</div>
        </div>
        <div class="airport-stat">
          <div class="number">503</div>
          <div class="label">Active STRs</div>
        </div>
        <div class="airport-stat">
          <div class="number">1 hr</div>
          <div class="label">From Toronto</div>
        </div>
        <div class="airport-stat">
          <div class="number">$0</div>
          <div class="label">License Fee</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section services-section">
    <div class="container">
      <div class="section-header">
        <h2>Full-Service Barrie Management</h2>
        <p>Everything included at 18%</p>
      </div>
      <div class="services-grid">
        {services.map(service => (
          <div class="service-item">
            <span class="service-check">✓</span>
            <span>{service}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section other-areas">
    <div class="container">
      <div class="section-header">
        <h2>Explore Our Other Service Areas</h2>
        <p>We manage properties across Ontario</p>
      </div>
      <div class="areas-grid">
        <a href="/full-airbnb-management-toronto" class="area-link">
          <span>Toronto</span>
          <span class="arrow">→</span>
        </a>
        <a href="/midland-airbnb-management" class="area-link">
          <span>Midland</span>
          <span class="arrow">→</span>
        </a>
        <a href="/calgary-airbnb-management" class="area-link">
          <span>Calgary</span>
          <span class="arrow">→</span>
        </a>
        <a href="/mont-tremblant-airbnb-management" class="area-link">
          <span>Mont-Tremblant</span>
          <span class="arrow">→</span>
        </a>
      </div>
      <p class="areas-cta">View all <a href="/locations">service areas</a> or learn more about our <a href="/services">services</a></p>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>Own a Barrie Property?</h2>
        <p>Get a free analysis showing how much your Barrie home, cottage, or investment property could earn on Airbnb. No license needed, no long-term contract, just more revenue.</p>
        <a href="/contact" class="btn btn-large">Get Your Free Analysis</a>
        <p class="cta-note">Free consultation • No obligation • Results in 24 hours</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-background-alt) 0%, var(--color-background) 100%);
    padding: 8rem 0 6rem;
    text-align: center;
    margin-top: -2rem;
  }

  .hero h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .hero .highlight { color: var(--color-primary); }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-light);
    margin: 0 auto 2rem;
    text-align: center;
    max-width: 600px;
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 4rem;
    margin: 3rem 0;
  }

  .stat { text-align: center; }
  .stat-number { font-size: 2.5rem; font-weight: 700; color: var(--color-primary); }
  .stat-label { color: var(--color-text-light); font-size: 0.9rem; }

  .neighborhoods-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .neighborhood-card {
    background: white;
    padding: 2rem;
    border-radius: 16px;
    box-shadow: var(--shadow-md);
    border-top: 4px solid var(--color-primary);
    transition: transform 0.3s ease;
  }

  .neighborhood-card:hover { transform: translateY(-5px); }
  .neighborhood-card h3 { font-size: 1.25rem; margin-bottom: 1rem; }
  .neighborhood-card p { color: var(--color-text-light); margin-bottom: 1rem; line-height: 1.7; }

  .avg-revenue {
    background: var(--color-background-alt);
    padding: 0.75rem 1rem;
    border-radius: 8px;
    font-weight: 600;
    color: var(--color-primary);
    font-size: 0.95rem;
  }

  .bylaws-section { background: var(--color-background-alt); }

  .bylaws-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .bylaw-card {
    background: white;
    padding: 2rem;
    border-radius: 16px;
    box-shadow: var(--shadow-sm);
  }

  .bylaw-card h3 { color: var(--color-primary); margin-bottom: 1rem; font-size: 1.25rem; }
  .bylaw-card p { color: var(--color-text-light); line-height: 1.7; }

  .why-section {
    background: var(--color-primary-dark);
    color: white;
  }

  .why-section .container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .why-content h2 {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
  }

  .why-content p {
    font-size: 1.125rem;
    line-height: 1.8;
    margin-bottom: 1.5rem;
    color: rgba(255, 255, 255, 0.9);
  }

  .airport-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .airport-stat {
    background: rgba(255, 255, 255, 0.1);
    padding: 1.5rem;
    border-radius: 12px;
    text-align: center;
  }

  .airport-stat .number {
    font-size: 2rem;
    font-weight: 700;
    color: #C9A961;
  }

  .airport-stat .label {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.8);
  }

  .services-section { background: var(--color-background-alt); }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .service-item {
    background: white;
    padding: 1.25rem 1.5rem;
    border-radius: 10px;
    display: flex;
    align-items: center;
    gap: 1rem;
    box-shadow: var(--shadow-sm);
  }

  .service-check { color: var(--color-primary); font-size: 1.25rem; font-weight: 700; }

  .cta-section {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    padding: 5rem 0;
    text-align: center;
    color: white;
  }

  .cta-content h2 { margin-bottom: 1rem; }
  .cta-content > p { font-size: 1.25rem; opacity: 0.9; margin-bottom: 2rem; max-width: 700px; margin-left: auto; margin-right: auto; }
  .cta-section .btn { background: white; color: var(--color-primary); }
  .cta-section .btn:hover { background: var(--color-background-alt); }
  .cta-note { margin-top: 1.5rem; font-size: 0.95rem; opacity: 0.9; }

  .other-areas { background: var(--color-background); }

  .areas-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .area-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: white;
    padding: 1.25rem 1.5rem;
    border-radius: 10px;
    text-decoration: none;
    color: var(--color-text);
    font-weight: 600;
    border: 1px solid var(--color-border);
    transition: all 0.3s ease;
  }

  .area-link:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .area-link .arrow { color: var(--color-primary); transition: transform 0.3s ease; }
  .area-link:hover .arrow { transform: translateX(4px); }

  .areas-cta { text-align: center; color: var(--color-text-light); }
  .areas-cta a { color: var(--color-primary); text-decoration: underline; }
  .areas-cta a:hover { color: var(--color-primary-dark); }

  @media (max-width: 968px) {
    .neighborhoods-grid, .services-grid { grid-template-columns: repeat(2, 1fr); }
    .bylaws-grid { grid-template-columns: 1fr; }
    .why-section .container { grid-template-columns: 1fr; }
    .areas-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 576px) {
    .hero-stats { flex-direction: column; gap: 2rem; }
    .neighborhoods-grid, .services-grid { grid-template-columns: 1fr; }
    .areas-grid { grid-template-columns: 1fr; }
  }
</style>
