                  <td style="padding:10px;border:1px solid #eee;text-align:center;">Yes</td>
                </tr>
                <tr>
                  <td style="padding:10px;border:1px solid #eee;font-weight:bold;"><a href="/blog/vaughan-airbnb-short-term-rental-guide-2026" style="color:#5a7d73;">Vaughan</a></td>
