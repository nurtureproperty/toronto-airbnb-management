];

const pageTitle = "Bowmanville Airbnb Short-Term Rental Rules 2026";
const pageDescription = "Bowmanville and Clarington have no STR license, no night limit, and no principal residence rule. One of Ontario's most Airbnb friendly municipalities.";

const articleSchema = {
