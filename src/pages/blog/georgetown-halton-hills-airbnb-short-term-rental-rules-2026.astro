];

const pageTitle = "Georgetown Halton Hills Airbnb Rules 2026 | STR Guide";
const pageDescription = "Short-term rentals are not permitted in Halton Hills via zoning omission. Mid-term rentals and B&Bs are alternatives. Regulation may be coming soon.";

const articleSchema = {
