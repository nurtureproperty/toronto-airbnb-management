---
import Layout from '../../layouts/Layout.astro';

const faqs = [
  { q: "Do I need a license to Airbnb in Whitby right now?", a: "No. As of early 2026, Whitby has no STR licensing requirement. You can list your property on Airbnb, VRBO, or any platform without a municipal permit. However, the Town is actively developing a licensing framework through ConnectWhitby.ca, so this will likely change. General bylaws for noise, parking, and property standards still apply." },
  { q: "What STR regulations are coming to Whitby?", a: "Whitby is actively developing a short-term rental licensing framework. While the exact rules haven't been finalized, neighbouring Oshawa's regulations (principal residence requirement, $150 license, 180-night limit, 5% MAT) offer a strong preview of what Durham Region cities tend to adopt. Monitor ConnectWhitby.ca for updates on public consultations and draft bylaws." },
  { q: "Can I Airbnb my investment property in Whitby?", a: "Yes, for now. Since Whitby has no principal residence requirement, you can operate an Airbnb on an investment property, a secondary residence, or your primary home. However, if Whitby follows Oshawa's model (which required principal residence), investment property STRs would become restricted. Consider this risk before investing heavily in an STR setup." },
  { q: "Should I wait to start hosting until rules are finalized?", a: "No reason to wait. You can legally operate right now, and building up your listing's reviews and ranking before regulations arrive gives you a head start. Hosts with established track records are often better positioned to meet licensing requirements. Just be prepared to adapt when rules come into effect." },
  { q: "Is there a night limit for Airbnb in Whitby?", a: "No. There is currently no cap on the number of nights per year you can rent your property. If Whitby follows Oshawa's model, a 180-night annual limit for entire-home rentals could be introduced. Partial rentals (renting rooms while you're home) are typically unlimited even in regulated cities." },
  { q: "Do I need to pay Municipal Accommodation Tax (MAT) in Whitby?", a: "No. Whitby does not currently collect MAT on short-term rentals. Neighbouring Oshawa charges 5% MAT, and most regulated Durham Region and GTA cities charge 4% to 5%. If Whitby introduces regulations, MAT will very likely be part of the package." },
  { q: "What insurance do I need for an Airbnb in Whitby?", a: "While there is no city-mandated insurance minimum right now, you should carry at least $2,000,000 in liability insurance that covers short-term rental activity. Standard homeowner's insurance typically excludes STR guests. Oshawa requires $2M liability insurance, and Whitby will likely require the same. Get covered now regardless." },
  { q: "How does Whitby compare to Oshawa for Airbnb hosting?", a: "Whitby is currently much more flexible. Oshawa requires a $150 license, principal residence, 180-night limit, 5% MAT, $2M insurance, property inspection, and a local contact person. Whitby has none of these requirements yet. However, Oshawa's regulations offer a preview of what Whitby will likely adopt. Ajax and Pickering, also in Durham Region, remain unregulated like Whitby." }
];

const relatedPosts = [
  { title: 'GTA Cities with No Airbnb License Required 2026', href: '/blog/gta-cities-no-airbnb-license-required-2026', description: 'Ajax, Pickering, Richmond Hill, and other GTA cities where you can host without a license' },
  { title: 'Oshawa Airbnb Short Term Rental Rules 2026', href: '/blog/oshawa-airbnb-short-term-rental-rules-2026', description: 'Whitby\'s neighbour requires a $150 license, 180 nights, 5% MAT, and principal residence' },
  { title: 'Airbnb Investment Property in the GTA', href: '/blog/airbnb-investment-property-gta', description: 'Which GTA cities allow investment property Airbnbs and what to know before you list' }
];

const tocItems = [
  { id: 'current-rules', text: 'Current Rules (2026)' },
  { id: 'whats-coming', text: "What's Coming" },
  { id: 'oshawa-preview', text: "Oshawa's Rules (A Preview)" },
  { id: 'what-applies-now', text: 'What Rules Apply Now' },
  { id: 'how-to-prepare', text: 'How to Prepare' },
  { id: 'comparison', text: 'Whitby vs Neighbours' },
  { id: 'tax-obligations', text: 'Tax Obligations' },
  { id: 'tips', text: 'Tips for Whitby Hosts' },
