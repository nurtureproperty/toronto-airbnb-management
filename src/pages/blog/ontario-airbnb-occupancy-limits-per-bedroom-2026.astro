  { id: 'faqs', text: 'FAQs' }
];

const pageTitle = "Ontario Airbnb Occupancy Limits Per Bedroom 2026";
const pageDescription = "Ontario Airbnb occupancy limits by city: Toronto has none, Burlington caps at 2 per bedroom. Full GTA comparison table with bylaw sources. Stay compliant.";

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": pageTitle,
  "description": pageDescription,
  "datePublished": "2026-03-12",
  "dateModified": "2026-03-12",
  "author": {
    "@type": "Organization",
    "name": "Nurture Airbnb Property Management",
    "url": "https://www.nurturestays.ca"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Nurture Airbnb Property Management",
