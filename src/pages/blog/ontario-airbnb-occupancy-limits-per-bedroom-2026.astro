---
import Layout from '../../layouts/Layout.astro';

const faqs = [
  { q: "What is the most common occupancy limit for Airbnb in Ontario?", a: "The most common rule across regulated Ontario cities is 2 persons per bedroom. Burlington, Milton, Hamilton, Ottawa, Oshawa, and Muskoka Lakes all use some version of this formula. Some cities like Milton and Niagara-on-the-Lake add a +2 buffer on top (so a 3-bedroom property allows 8 guests total). Cities without explicit per-bedroom limits, like Toronto and Mississauga, leave it to hosts and platforms to set their own caps." },
  { q: "Does Toronto have a maximum occupancy per bedroom for Airbnb?", a: "No. Toronto's short-term rental bylaw (Chapter 547) does not include any per-bedroom occupancy limits. You can set your own guest limits based on what makes sense for your property, your insurance policy, and your comfort level. That said, Airbnb's own platform caps listings at 16 guests maximum, and most hosts set limits based on available sleeping arrangements." },
  { q: "What happens if guests exceed the occupancy limit?", a: "In cities with demerit point systems like Burlington and Oakville, exceeding maximum occupancy can earn you 3 to 5 demerit points per incident. At 7 points, your license gets suspended for up to 6 months. At 15 points, it's revoked. In other cities, you face fines that can range from $500 to $100,000 depending on the municipality." },
  { q: "Do children count toward Airbnb occupancy limits?", a: "It depends on the city. Hamilton and Muskoka Lakes specifically exclude children aged 2 and under from occupancy counts. Brampton counts children under 12 as 0.5 persons. Most other regulated cities don't make any age distinction, so all guests count equally regardless of age." },
  { q: "Can I add extra mattresses to increase my guest capacity?", a: "Not in cities with per-bedroom occupancy rules. Burlington's bylaw specifically states the limit is based on 'legal bedrooms' that meet Building Code and Fire Code requirements. You can't convert a den, living room, or closet into a bedroom just by adding a mattress. The bedroom must be on your approved floor plan." },
  { q: "Does Mississauga have occupancy limits for Airbnb?", a: "No. Mississauga's STR bylaw does not include per-bedroom occupancy limits. Like Toronto, the city regulates STRs through licensing, principal residence requirements, and night caps (180 days/year), but does not dictate how many guests can sleep in each bedroom." },
  { q: "How do occupancy limits affect my Airbnb pricing?", a: "Properties in cities without occupancy limits (Toronto, Mississauga, Vaughan, Oakville) can accommodate larger groups and charge accordingly. A 5-bedroom Toronto home can sleep 10 to 16 guests and charge premium rates for group travel. In Burlington, that same 5-bedroom property is capped at 12 guests (2 per bedroom + 2). This matters most during peak events like the FIFA World Cup when large group demand surges." },
  { q: "What if my city doesn't have occupancy rules?", a: "Even without city-imposed limits, you should still set reasonable occupancy caps. Your insurance policy likely has guest limits. Airbnb caps at 16. Condo corporations may have their own rules. And from a practical standpoint, overcrowding leads to noise complaints, faster wear on your property, and lower reviews. A good rule of thumb is 2 guests per bedroom plus 2, which matches what most regulated cities require." }
];

const relatedPosts = [
  { title: "Toronto Airbnb Short Term Rental Regulations 2026", href: '/blog/toronto-airbnb-short-term-rental-regulations-2026', description: 'Complete Toronto STR rules: 180-night limit, registration, MAT tax, and compliance tips' },
  { title: "Burlington Airbnb Short Term Rental Rules 2026", href: '/blog/burlington-airbnb-short-term-rental-rules-2026', description: 'Burlington demerit point system, 183-night limit, and 2 adults per bedroom rule' },
  { title: "Airbnb Guest Screening & Party Prevention Guide", href: '/blog/airbnb-guest-screening-party-prevention-guide-2026', description: 'Vet guests effectively to prevent occupancy violations and protect your license' }
];

const tocItems = [
  { id: 'why-occupancy-matters', text: 'Why Occupancy Limits Matter' },
  { id: 'quick-reference', text: 'Quick Reference Table' },
  { id: 'cities-with-limits', text: 'Cities WITH Limits' },
  { id: 'cities-without-limits', text: 'Cities WITHOUT Limits' },
  { id: 'children-exemptions', text: 'Children & Exemptions' },
  { id: 'enforcement', text: 'Enforcement & Penalties' },
