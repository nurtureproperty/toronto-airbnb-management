---
import Layout from '../../layouts/Layout.astro';

const faqs = [
  { q: "Do I need a license to Airbnb in Hastings Highlands?", a: "No. As of 2026, Hastings Highlands has no STR licensing requirement. There is no permit, registration, or approval needed to operate a short-term rental. The municipality's Business Licensing By-law 2024-005 only covers vendors, mobile food trucks, markets, and door-to-door sales. Standard bylaws for noise, property standards, and fire safety still apply." },
  { q: "Can I Airbnb my cottage or investment property in Hastings Highlands?", a: "Yes. Hastings Highlands has no principal residence requirement, so you can operate a short-term rental on an investment property, a seasonal cottage, or your primary home. This is a major advantage over cities like Toronto, Muskoka Lakes, and Huntsville, which restrict STRs to principal residences." },
  { q: "Is there a night limit for Airbnb in Hastings Highlands?", a: "No. There is no cap on the number of nights per year you can rent your property. You can operate 365 nights a year. Nearby Huntsville and Muskoka Lakes both have restrictions and licensing requirements." },
  { q: "Do I need to pay Municipal Accommodation Tax (MAT) in Hastings Highlands?", a: "No. Hastings Highlands does not collect MAT on short-term rentals. Nearby Muskoka Lakes and Huntsville both charge MAT. That means higher net revenue per booking for Hastings Highlands hosts." },
  { q: "How much can I earn on Airbnb in Hastings Highlands?", a: "According to Airbtics, the average annual revenue for a Hastings Highlands Airbnb is CA$49,221 with 54% occupancy. AirROI data for the Bancroft area shows median annual revenue of $29,946, with top 10% of hosts earning $7,193 or more per month (over $86,000 per year). Peak summer months see 58.6% occupancy at $219 average daily rate." },
  { q: "Will Hastings Highlands regulate short-term rentals in the future?", a: "There are no current proposals. Neighbouring Centre Hastings explicitly rejected STR regulation in April 2024 after a community survey found 61% of residents said short-term rentals were not disrupting their lives. However, surrounding cottage country areas like Muskoka Lakes and Kawartha Lakes have adopted regulations, which could eventually push provincial or regional action." },
  { q: "Do I need to collect HST on my Airbnb income in Hastings Highlands?", a: "If your total STR revenue exceeds $30,000 per year across all properties, you must register for HST (13%) and charge it on bookings. Below that threshold, HST registration is optional. Airbnb collects and remits HST automatically on platform bookings if you provide your HST number." },
  { q: "What insurance do I need for an Airbnb in Hastings Highlands?", a: "While Hastings Highlands has no city mandated insurance minimum, you should carry at least $2,000,000 in liability insurance that explicitly covers short-term rental activity. Standard homeowner's insurance typically excludes STR guests. Cottage insurance policies often have additional exclusions for commercial use, so make sure your policy explicitly covers short-term rentals." },
  { q: "What types of properties perform best in Hastings Highlands?", a: "Cottages and houses dominate the market. About 66.7% of listings are houses or cottages, and 90.5% are entire home listings. Waterfront cottages on any of the area's 180+ lakes tend to command the highest rates, especially during peak summer months when the average daily rate hits $219." },
  { q: "When do most guests book in Hastings Highlands?", a: "The average booking lead time is 57 days, but this varies dramatically by season. Summer bookings average 86 days of lead time, meaning guests are planning their cottage trips nearly three months in advance. Winter bookings have a much shorter 32 day lead time. Price your summer calendar early to capture those advance bookings." }
];

const relatedPosts = [
  { title: 'Foxboro & Belleville Airbnb Rules 2026', href: '/blog/foxboro-belleville-airbnb-short-term-rental-rules-2026', description: 'Belleville allows investment properties with a $1,000 license, 130 cap, and no principal residence rule' },
  { title: 'Muskoka Lakes Airbnb Short Term Rental Rules 2026', href: '/blog/muskoka-lakes-airbnb-short-term-rental-rules-2026', description: 'Muskoka Lakes charges $1,000/year for a license and uses a demerit point system' },
  { title: 'Huntsville Airbnb Short Term Rental Rules 2026', href: '/blog/huntsville-airbnb-short-term-rental-rules-2026', description: 'Huntsville requires 12 months of ownership before you can even apply for an STR license' }
