import Layout from '../../layouts/Layout.astro';

const faqs = [
  { q: "Should I claim CCA on my Airbnb building?", a: "No. Your Airbnb is your principal residence. Claiming CCA on the building risks your principal residence exemption, which shelters the entire capital gain when you sell. CCA on the building is just a tax deferral anyway: you save now but pay it all back through recapture when you sell. CCA on contents (furniture, linens, electronics) is a different story. Claim those freely." },
  { q: "What is CCA recapture?", a: "When you sell a property you claimed CCA on, the CCA you deducted gets added back to your income at 100% inclusion. That's worse than capital gains, which are only 50% inclusion. If you claimed $60,000 in building CCA, you owe tax on the full $60,000 as ordinary income when you sell." },
  { q: "What CCA can I claim on my Airbnb furnishings?", a: "Class 8 (20% per year) covers furniture and appliances like beds, couches, fridges, and washers. Class 12 (100%) covers linens, towels, dishes, cutlery, and kitchen utensils under $500. Class 50 (55%) covers electronics like smart locks, security cameras, and noise monitors. These don't affect your principal residence exemption." },
  { q: "Does part-time Airbnb use trigger a change of use?", a: "Not if three conditions are met: the rental use is relatively small compared to personal use, you made no structural changes, and you don't claim CCA on the building. If you live in your home most of the year and Airbnb it when you travel, CRA treats this as continued personal use. No deemed disposition. Full principal residence exemption." },
  { q: "What if I Airbnb all 180 nights in Toronto?", a: "At 180 out of 365 nights (~49% rental use), you're in a grey area. CRA could argue the rental use is no longer 'relatively small.' The safest approach: don't claim building CCA and don't make structural changes. That keeps your principal residence exemption intact and preserves the 45(2) election as a backup if CRA ever challenges." },
  { q: "What is the 45(2) election?", a: "If you move out and convert your home to a full-time Airbnb, CRA treats it as if you sold the property. The 45(2) election defers this and lets you keep designating the home as your principal residence for up to 4 more years while it's rented. The one condition: you must never claim CCA on the building, or the election is voided." },
  { q: "Do I need to collect HST on my Airbnb income?", a: "If your gross STR revenue exceeds $30,000 in any rolling four consecutive quarters (or a single quarter), you must register for HST within 29 days. Below that threshold, registration is optional. Airbnb already collects and remits HST on platform bookings for unregistered hosts. Once you register, you take over HST collection but can claim Input Tax Credits on business expenses like furniture, cleaning, and photography." },
  { q: "Should I register for HST voluntarily before hitting $30K?", a: "It depends on your startup costs. If you're furnishing a property from scratch and spending $10,000+ on furniture and supplies, voluntary registration lets you claim back the 13% HST on those purchases as Input Tax Credits. If you're renting a spare room with existing furniture, the extra paperwork isn't worth it. One caution: if you register and later stop hosting, CRA may treat the conversion as a change of use, which can trigger HST on the property's fair market value. Talk to your accountant first." },
  { q: "Is Airbnb or long-term rental better for taxes?", a: "If you live in the property, Airbnb is better because you keep your principal residence exemption (tax-free sale). Long-term rental means moving out, which triggers a deemed disposition and starts the clock on taxable capital gains. Airbnb also has more deductible expenses (cleaning, linens, furnishings) and HST Input Tax Credits if registered. Long-term rental is simpler (no HST, no MAT, no STR license needed) but you lose the PRE, which is usually worth far more than any deduction." },
  { q: "What happens to my principal residence exemption when I sell?", a: "If you never claimed CCA on the building, made no structural changes for rental purposes, and your rental use was ancillary, the full exemption applies. The entire capital gain is tax-free. This is why protecting the PRE matters more than any CCA deduction." }
];

const relatedPosts = [
