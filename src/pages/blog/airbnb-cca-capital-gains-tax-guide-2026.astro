---
import Layout from '../../layouts/Layout.astro';

const faqs = [
  { q: "Should I claim CCA on my Airbnb building?", a: "In most cases, no. CCA on the building saves you tax now but costs you the same tax (or more) through recapture when you sell. Worse, it permanently blocks the 45(3) election and can void the 45(2) election, both of which shelter far more capital gains than the CCA ever saved. CCA on contents like furniture, linens, and electronics is almost always worth claiming since those items genuinely depreciate and don't affect your principal residence exemption." },
  { q: "What is CCA recapture and how is it taxed?", a: "Recapture happens when you sell a depreciable asset for more than its remaining undepreciated capital cost (UCC). The recaptured amount is taxed as 100% ordinary income at your full marginal rate. This is worse than capital gains treatment, which is only 50% inclusion. For example, if you claimed $60,000 in building CCA and sell above UCC, that $60,000 is fully taxable as income, not as a capital gain." },
  { q: "What is the 45(2) election?", a: "The 45(2) election lets you defer the deemed disposition that normally occurs when you convert your principal residence into a rental property. It allows you to continue designating the property as your principal residence for up to 4 additional years while it's being rented. The key condition: you must never claim CCA on the building, or the election is automatically rescinded." },
  { q: "What is the 45(3) election?", a: "The 45(3) election lets you defer the deemed disposition when you convert a rental property into your principal residence. Filed when you eventually sell (not when you move in), it allows you to retroactively designate up to 4 years of the rental period as principal residence years. The critical condition: if you ever claimed CCA on the building after 1984, this election is permanently unavailable." },
  { q: "Can I claim CCA on Airbnb furniture and still keep the principal residence exemption?", a: "Yes. CCA on contents like furniture (Class 8), linens (Class 12), and electronics (Class 50) does not affect your principal residence exemption. The restriction only applies to CCA claimed on the building itself (Class 1 or Class 3). Claim CCA on your contents without worry." },
  { q: "What CCA classes apply to Airbnb furnishings?", a: "Class 8 (20%) covers furniture and appliances like beds, couches, fridges, and washers. Class 12 (100%) covers linens, towels, dishes, cutlery, and kitchen utensils under $500. Class 50 (55%) covers electronics like smart locks, security cameras, noise monitors, and computers. Class 12 items are particularly valuable since you write off the full cost." },
  { q: "Does part-time Airbnb use trigger a change of use?", a: "Not if three conditions are met: the rental use is relatively small compared to personal use, you made no structural changes to the property, and you don't claim CCA on the building. If you live in your condo most of the year and Airbnb it occasionally, CRA generally treats this as continued personal use with no deemed disposition." },
  { q: "What happens if I Airbnb for more than 4 years after moving out?", a: "With the 45(2) election, you can designate the property as your principal residence for up to 4 years (5 with the plus-one rule). Any appreciation beyond that window is taxable as a capital gain when you sell. There is an exception: if you moved for employer-required relocation (40+ km farther from the property), the 4-year limit is removed entirely under section 54.1." }
];

const relatedPosts = [
  { title: 'Airbnb Taxes Canada 2026: GTA Host Tax Guide', href: '/blog/airbnb-taxes-canada-gta-guide-2026', description: 'Income tax, HST registration, MAT, and deductible expenses for Ontario hosts' },
  { title: 'Can I Airbnb My Investment Property in the GTA?', href: '/blog/airbnb-investment-property-gta', description: 'Principal residence rules and which Ontario cities allow investment property STRs' },
  { title: 'Airbnb Insurance Ontario Host Guide 2026', href: '/blog/airbnb-insurance-ontario-host-guide-2026', description: 'Liability coverage, AirCover gaps, and what Ontario hosts actually need' }
];

const tocItems = [
  { id: 'what-is-cca', text: 'What Is CCA?' },
  { id: 'cca-classes', text: 'CCA Classes for Airbnb Hosts' },
  { id: 'the-cca-trap', text: 'The CCA Trap (Read This First)' },
  { id: 'when-cca-worth-it', text: 'When CCA IS Worth Claiming' },
  { id: 'change-of-use', text: 'Change of Use Rules' },
