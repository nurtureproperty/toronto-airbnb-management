---
import Layout from '../layouts/Layout.astro';

const pageTitle = "Toronto Airbnb Income Calculator 2026 | Free Revenue Estimate";
const pageDescription = "How much can you earn on Airbnb in Toronto? Average hosts make $3,667/mo, top 10% earn $5,657+. See revenue by neighborhood and bedrooms. Free estimate.";

const torontoData = [
  { metric: "Average Monthly Revenue", value: "$3,667", source: "Airbtics" },
  { metric: "Top 25% Monthly Revenue", value: "$3,476+", source: "AirROI" },
  { metric: "Top 10% Monthly Revenue", value: "$5,657+", source: "AirROI" },
  { metric: "Average Nightly Rate (ADR)", value: "$168", source: "Airbtics" },
  { metric: "Top 25% Nightly Rate", value: "$185+", source: "AirROI" },
  { metric: "Top 10% Nightly Rate", value: "$292+", source: "AirROI" },
  { metric: "Average Occupancy", value: "70%", source: "Airbtics" },
  { metric: "Top 25% Occupancy", value: "74%+", source: "AirROI" },
  { metric: "Top 10% Occupancy", value: "88%+", source: "AirROI" },
  { metric: "Active Listings", value: "10,326", source: "AirROI" },
];

const faqs = [
  { q: "How accurate are these Toronto Airbnb revenue estimates?", a: "The revenue figures are market averages from Airbtics and AirROI, based on thousands of active Airbnb listings across Toronto. Your actual revenue depends on your specific property: exact location, quality of furnishing, photos, pricing strategy, and guest reviews. Top 25% performers consistently earn 50-100% more than the average. A free consultation gives you a personalized estimate based on your exact property." },
  { q: "What expenses should I subtract from these revenue numbers?", a: "The numbers shown are gross revenue before expenses. Typical expenses for a managed property include: management fee (12-15% with Nurture), cleaning costs ($80-150 per turnover, usually covered by the guest cleaning fee), supplies and restocking ($50-100/month), insurance ($100-200/month), and platform fees (Airbnb takes 3% from hosts). Your mortgage, property tax, and utilities are costs you'd pay regardless of rental strategy." },
  { q: "How much more can I make with a property manager vs self-managing?", a: "Our analysis of 320 Toronto listings found that professionally managed properties with dynamic pricing earn $4,460+/month on average, compared to $2,020/month for self-managed listings with static pricing. That is a 64% difference. Even after the management fee, most owners net more with professional management because of better pricing, faster response times, and higher search ranking." },
  { q: "Can I Airbnb my investment property in Toronto?", a: "Toronto requires short-term rentals to be your principal residence. Investment properties cannot be used for stays under 28 days. However, mid-term rentals (30+ days) are exempt from Toronto's STR rules and can still generate strong returns. We manage both short-term and mid-term properties across Toronto." },
  { q: "Why is there such a big gap between average and top earners in Toronto?", a: "The difference comes down to three things: listing quality (professional photos, optimized title and description), pricing strategy (dynamic pricing adjusted daily vs flat rates), and guest experience (fast response times, spotless cleaning, great amenities). Top performers nail all three. That is exactly what a good management company handles for you." },
  { q: "Do these numbers account for the 180 night limit in Toronto?", a: "The averages include all listing types. In Toronto, entire-home rentals are capped at 180 nights per year, but partial-unit rentals (renting rooms while home) have no limit. Many hosts switch to mid-term rentals (30+ days) for the remaining months, which are exempt from the cap. A blended strategy of 180 nights STR plus mid-term for the rest of the year can outperform either strategy alone." },
  { q: "Which Toronto neighborhoods earn the most on Airbnb?", a: "Downtown neighborhoods near the Entertainment District, King West, Yorkville, and the Financial District command the highest nightly rates. Properties close to transit, restaurants, and tourist attractions consistently outperform. The top 10% of Toronto hosts earn $292+ per night with 88%+ occupancy regardless of exact neighborhood, which shows that listing quality and pricing strategy matter as much as location." },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};
---

<Layout title={pageTitle} description={pageDescription} schema={faqSchema}>

  <!-- Hero -->
  <section class="calc-hero">
    <div class="container">
      <div class="calc-hero-content">
        <h1>How Much Can You Earn on Airbnb in Toronto?</h1>
        <p>See real revenue data by Toronto neighborhood and bedroom count, then get a free personalized estimate for your property.</p>
      </div>
    </div>
  </section>

  <!-- Revenue Table -->
  <section class="calc-data">
    <div class="container">
      <h2>Toronto Airbnb Revenue: The Full Picture</h2>
      <p class="data-subtitle">Based on market data from Airbtics and AirROI. All figures in CAD. Data period: Feb 2025 to Jan 2026.</p>

      <div class="table-wrapper">
        <table class="revenue-table">
          <thead>
            <tr>
              <th>Metric</th>
              <th>Average Host</th>
              <th>Top 25%</th>
              <th>Top 10%</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="city-name">Monthly Revenue</td>
              <td class="revenue">$3,667</td>
              <td class="revenue good">$3,476+</td>
              <td class="revenue great">$5,657+</td>
            </tr>
            <tr>
              <td class="city-name">Nightly Rate (ADR)</td>
              <td class="revenue">$168</td>
              <td class="revenue good">$185+</td>
              <td class="revenue great">$292+</td>
            </tr>
            <tr>
              <td class="city-name">Occupancy Rate</td>
              <td class="revenue">70%</td>
              <td class="revenue good">74%+</td>
              <td class="revenue great">88%+</td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="data-subtitle" style="margin-top: 1rem;">There are over <strong>10,300 active Airbnb listings</strong> in Toronto. The average host earns <strong>$3,667/month</strong>, but the top 10% earn <strong>$5,657+</strong>. That is a $2,000/month gap driven by three things: professional photos, dynamic pricing, and fast guest response times. Revenue grew 15.5% year over year.</p>

      <div class="data-callout">
        <p><strong>Where would your property fall?</strong> Most self-managed hosts with flat pricing land in the average column. Hosts with professional management, daily pricing adjustments, and optimized listings consistently land in the Top 25% or Top 10%. A free consultation tells you exactly where your specific property would land.</p>
      </div>
    </div>
  </section>

  <!-- Toronto Nightly Rates by Bedroom -->
  <section class="calc-bedrooms">
    <div class="container">
      <h2>Toronto Airbnb Occupancy by Bedroom Count</h2>
      <div class="bedroom-grid">
        <div class="bedroom-card">
          <div class="bed-count">Studio</div>
          <div class="bed-range">73%<span> avg occupancy</span></div>
          <div class="bed-occ">Highest occupancy. Compact, affordable, fills fast.</div>
        </div>
        <div class="bedroom-card">
          <div class="bed-count">1 BR</div>
          <div class="bed-range">72%<span> avg occupancy</span></div>
          <div class="bed-occ">The most common Toronto Airbnb type. Strong demand year round.</div>
        </div>
        <div class="bedroom-card">
          <div class="bed-count">2 BR</div>
          <div class="bed-range">70%<span> avg occupancy</span></div>
          <div class="bed-occ">Higher nightly rate offsets slightly lower occupancy.</div>
        </div>
        <div class="bedroom-card">
          <div class="bed-count">3 BR</div>
          <div class="bed-range">67%<span> avg occupancy</span></div>
          <div class="bed-occ">Attracts families and groups. Premium pricing on weekends.</div>
        </div>
        <div class="bedroom-card">
          <div class="bed-count">4 BR</div>
          <div class="bed-range">63%<span> avg occupancy</span></div>
          <div class="bed-occ">Lower occupancy but much higher revenue per booking.</div>
        </div>
        <div class="bedroom-card">
          <div class="bed-count">5+ BR</div>
          <div class="bed-range">55-61%<span> avg occupancy</span></div>
          <div class="bed-occ">Luxury and group rentals. Fewer bookings but top dollar per night.</div>
        </div>
      </div>
      <p class="bed-note">Occupancy data from Airbtics (Feb 2025 to Jan 2026). Smaller properties fill more consistently, but larger properties earn more per booking. The city-wide average ADR is $168/night, with the top 10% earning $292+/night.</p>
    </div>
  </section>

  <!-- Seasonality -->
  <section class="calc-seasons" style="background: var(--color-bg-alt);">
    <div class="container">
      <h2>When Do Toronto Airbnbs Earn the Most?</h2>
      <div class="season-grid">
        <div class="season-card peak">
          <h3>Peak Season</h3>
          <p class="season-months">July, August, September</p>
          <p class="season-revenue">$3,319/mo average</p>
          <p class="season-detail">58.9% occupancy, $155/night ADR</p>
          <p class="season-events">TIFF, Caribana, CNE, Pride, summer tourism</p>
        </div>
        <div class="season-card shoulder">
          <h3>Shoulder Season</h3>
          <p class="season-months">April, May, June, October, November</p>
          <p class="season-revenue">$2,200 to $2,800/mo</p>
          <p class="season-detail">Building to/from peak rates</p>
          <p class="season-events">FIFA World Cup (June 2026), Victoria Day, Thanksgiving</p>
        </div>
        <div class="season-card slow">
          <h3>Slow Season</h3>
          <p class="season-months">January, February, March</p>
          <p class="season-revenue">$1,857/mo average</p>
          <p class="season-detail">42.3% occupancy, $139/night ADR</p>
          <p class="season-events">March Break is a brief spike. Many hosts switch to mid-term.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Case Studies -->
  <section class="calc-cases">
    <div class="container">
      <h2>Real Results from Nurture Clients</h2>
      <div class="case-grid">
        <div class="case-card">
          <div class="case-type">1 Bedroom Condo, GTA</div>
          <div class="case-before">Before: <strong>-$926/mo</strong> <span>(long-term rental)</span></div>
          <div class="case-after">After: <strong>+$847/mo</strong> <span>(Airbnb with Nurture)</span></div>
          <div class="case-result">87% cashflow increase in first month</div>
        </div>
        <div class="case-card">
          <div class="case-type">1 Bedroom Condo, Toronto</div>
          <div class="case-revenue">$4,123/mo</div>
          <div class="case-result">After switching to Nurture management</div>
        </div>
        <div class="case-card">
          <div class="case-type">Average Managed Listing</div>
          <div class="case-revenue">$4,460+/mo</div>
          <div class="case-result">Across all Nurture managed properties</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA + Form -->
  <section class="calc-cta" style="background: var(--color-bg-alt);">
    <div class="container">
      <div class="cta-content">
        <h2>Get Your Free Personalized Estimate</h2>
        <p>Market averages are a starting point. Your property is unique. Book a free 15 minute consultation and we'll give you a custom revenue projection based on your specific property, neighborhood, and setup.</p>
        <div class="cta-bullets">
          <div class="cta-bullet">Custom revenue projection for your exact property</div>
          <div class="cta-bullet">Expense breakdown so you see real profit, not just revenue</div>
          <div class="cta-bullet">Honest assessment of whether Airbnb makes sense for you</div>
          <div class="cta-bullet">No obligation, no pressure</div>
        </div>
      </div>
      <div class="form-card">
        <div class="form-card-header">
          <h3>Book Your Free Consultation</h3>
          <p>Pick a time that works for you</p>
        </div>
        <iframe
          data-src="https://api.nurtre.io/widget/booking/VGvuhzjQT58ZPGHt0LUV"
          style="width:100%;border:none;overflow:auto;height:1000px"
          id="calc_form_iframe"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="calc-faq">
    <div class="container">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqs.map(f => (
          <div class="faq-item">
            <h3>{f.q}</h3>
            <p>{f.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Sources -->
  <section class="calc-sources">
    <div class="container">
      <p class="sources-text">Revenue and occupancy data from <a href="https://airbtics.com/annual-airbnb-revenue-in-toronto-ontario-canada/" target="_blank" rel="noopener">Airbtics</a> (Feb 2025 to Jan 2026 trailing data) and <a href="https://www.airroi.com/report/world/canada/ontario/toronto" target="_blank" rel="noopener">AirROI</a> (2026 current data). All figures in CAD. Figures represent market averages across 10,300+ Toronto listings and may vary based on property specifics.</p>
    </div>
  </section>

</Layout>

<script is:inline>
  var formLoaded = false;
  function loadCalcForm() {
    if (formLoaded) return;
    formLoaded = true;
    var iframe = document.getElementById('calc_form_iframe');
    if (iframe && iframe.dataset.src) {
      iframe.src = iframe.dataset.src;
      var s = document.createElement('script');
      s.src = 'https://api.nurtre.io/js/form_embed.js';
      document.body.appendChild(s);
    }
  }
  var fo = new IntersectionObserver(function(entries) {
    if (entries[0].isIntersecting) { fo.disconnect(); setTimeout(loadCalcForm, 200); }
  }, { rootMargin: '200px' });
  var fc = document.querySelector('.form-card');
  if (fc) fo.observe(fc);
</script>

<style>
  /* Hero */
  .calc-hero {
    background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-primary) 100%);
    color: white;
    padding: 3rem 0 3.5rem;
    text-align: center;
  }
  .calc-hero-content { max-width: 700px; margin: 0 auto; }
  .calc-hero h1 { font-size: clamp(1.75rem, 3.5vw, 2.5rem); margin-bottom: 0.75rem; }
  .calc-hero p { font-size: 1.1rem; opacity: 0.9; line-height: 1.6; }

  /* Revenue Table */
  .calc-data { padding: 3rem 0; }
  .calc-data h2 { text-align: center; margin-bottom: 0.5rem; }
  .data-subtitle { text-align: center; color: var(--color-text-light); margin-bottom: 2rem; font-size: 0.95rem; }

  .table-wrapper { overflow-x: auto; margin-bottom: 1.5rem; }
  .revenue-table { width: 100%; border-collapse: collapse; font-size: 0.95rem; }
  .revenue-table th { background: var(--color-primary); color: white; padding: 0.75rem 1rem; text-align: left; font-weight: 600; white-space: nowrap; }
  .revenue-table td { padding: 0.75rem 1rem; border-bottom: 1px solid #eee; }
  .revenue-table tbody tr:hover { background: #f8f8f8; }
  .city-name { font-weight: 600; }
  .revenue { font-weight: 600; }
  .revenue.good { color: var(--color-primary-dark); }
  .revenue.great { color: #1a7a4c; }

  .data-callout { background: var(--color-bg-alt); padding: 1.25rem 1.5rem; border-radius: 8px; border-left: 4px solid var(--color-primary); }
  .data-callout p { margin: 0; font-size: 0.95rem; line-height: 1.6; }

  /* Bedroom Cards */
  .calc-bedrooms { padding: 3rem 0; background: var(--color-bg-alt); }
  .calc-bedrooms h2 { text-align: center; margin-bottom: 2rem; }
  .bedroom-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; max-width: 850px; margin: 0 auto; }
  .bedroom-card { background: white; border-radius: 12px; padding: 1.5rem; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
  .bed-count { font-size: 1.5rem; font-weight: 700; color: var(--color-primary-dark); margin-bottom: 0.5rem; }
  .bed-range { font-size: 1.1rem; font-weight: 600; margin-bottom: 0.25rem; }
  .bed-range span { font-size: 0.85rem; font-weight: 400; color: var(--color-text-light); }
  .bed-occ { font-size: 0.85rem; color: var(--color-text-light); }
  .bed-note { text-align: center; color: var(--color-text-light); font-size: 0.9rem; margin-top: 1.5rem; max-width: 600px; margin-left: auto; margin-right: auto; }

  /* Seasonality */
  .calc-seasons { padding: 3rem 0; }
  .calc-seasons h2 { text-align: center; margin-bottom: 2rem; }
  .season-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; max-width: 900px; margin: 0 auto; }
  .season-card { background: white; border-radius: 12px; padding: 1.5rem; border-top: 4px solid #ccc; }
  .season-card.peak { border-top-color: #1a7a4c; }
  .season-card.shoulder { border-top-color: var(--color-accent); }
  .season-card.slow { border-top-color: #c0392b; }
  .season-card h3 { margin-bottom: 0.25rem; font-size: 1.1rem; }
  .season-months { font-size: 0.85rem; color: var(--color-text-light); margin-bottom: 0.75rem; }
  .season-revenue { font-size: 1.25rem; font-weight: 700; color: var(--color-primary-dark); margin-bottom: 0.25rem; }
  .season-detail { font-size: 0.85rem; color: var(--color-text-light); margin-bottom: 0.5rem; }
  .season-events { font-size: 0.85rem; color: var(--color-text-light); font-style: italic; }

  /* Case Studies */
  .calc-cases { padding: 3rem 0; }
  .calc-cases h2 { text-align: center; margin-bottom: 2rem; }
  .case-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; max-width: 900px; margin: 0 auto; }
  .case-card { background: white; border-radius: 12px; padding: 1.5rem; box-shadow: 0 2px 8px rgba(0,0,0,0.06); text-align: center; }
  .case-type { font-size: 0.85rem; color: var(--color-text-light); margin-bottom: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; }
  .case-before { font-size: 0.95rem; margin-bottom: 0.25rem; }
  .case-before strong { color: #c0392b; }
  .case-after { font-size: 0.95rem; margin-bottom: 0.5rem; }
  .case-after strong { color: #1a7a4c; }
  .case-revenue { font-size: 1.5rem; font-weight: 700; color: var(--color-primary-dark); margin-bottom: 0.5rem; }
  .case-result { font-size: 0.85rem; color: var(--color-text-light); }

  /* CTA + Form */
  .calc-cta { padding: 3rem 0; }
  .calc-cta .container { max-width: 700px; }
  .cta-content { text-align: center; margin-bottom: 2rem; }
  .cta-content h2 { margin-bottom: 0.75rem; }
  .cta-content > p { color: var(--color-text-light); line-height: 1.6; margin-bottom: 1.5rem; }
  .cta-bullets { display: flex; flex-direction: column; gap: 0.5rem; align-items: center; }
  .cta-bullet { font-size: 0.95rem; color: var(--color-text); }
  .cta-bullet::before { content: "✓ "; color: var(--color-primary); font-weight: bold; }

  .form-card { background: white; border-radius: 16px; box-shadow: 0 8px 40px rgba(0,0,0,0.1); overflow: hidden; border: 1px solid var(--color-border); }
  .form-card-header { padding: 1.5rem 1.5rem 0.5rem; text-align: center; }
  .form-card-header h3 { font-size: 1.2rem; margin-bottom: 0.25rem; }
  .form-card-header p { color: var(--color-text-light); font-size: 0.9rem; }

  /* FAQ */
  .calc-faq { padding: 3rem 0; }
  .calc-faq h2 { text-align: center; margin-bottom: 2rem; }
  .faq-list { max-width: 700px; margin: 0 auto; }
  .faq-item { border-bottom: 1px solid #eee; padding: 1.25rem 0; }
  .faq-item h3 { font-size: 1.05rem; margin-bottom: 0.5rem; color: var(--color-text); }
  .faq-item p { color: var(--color-text-light); line-height: 1.6; font-size: 0.95rem; margin: 0; }

  /* Sources */
  .calc-sources { padding: 1.5rem 0 3rem; }
  .sources-text { font-size: 0.8rem; color: #999; text-align: center; max-width: 700px; margin: 0 auto; }
  .sources-text a { color: #999; text-decoration: underline; }

  /* Mobile */
  @media (max-width: 768px) {
    .bedroom-grid, .season-grid, .case-grid { grid-template-columns: 1fr; }
    .revenue-table { font-size: 0.85rem; }
    .revenue-table th, .revenue-table td { padding: 0.5rem 0.6rem; }
  }
</style>
