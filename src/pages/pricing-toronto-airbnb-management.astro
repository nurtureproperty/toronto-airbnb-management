---
import Layout from '../layouts/Layout.astro';

const pricingTiers = [
  {
    name: 'Professional',
    rate: '15%',
    description: 'Full-service management for busy property owners. We handle everything.',
    features: [
      'Professional listing creation',
      'Multi-platform distribution',
      'Dynamic pricing optimization',
      'Guest communication',
      'Guest vetting & screening',
      'Review management',
      'Monthly performance reports',
      'Booking management',
      'Professional cleaning coordination',
      'Linen & supply restocking',
      'Smart lock management',
      'Dedicated account manager',
      'Contractor coordination',
      'Insurance claim assistance',
      'Airbnb Guest E-book',
      'Furnishing consulting'
    ],
    notIncluded: [],
    popular: true
  }
];

const benefits = [
  {
    title: 'Management fees at just 15%',
    description: 'Others charge more and do less'
  },
  {
    title: 'Less than 9 minute average guest response time',
    description: 'Others cost you bookings with their slow speed'
  },
  {
    title: 'Locally owned and operated in the GTA',
    description: 'We understand the bylaws and market'
  },
  {
    title: 'No long contracts',
    description: 'Others make leaving hard'
  },
  {
    title: 'Marketing experts with years of experience',
    description: 'Others use virtual assistants'
  },
  {
    title: 'Direct support. Text or call us direct',
    description: 'Others stick you in a groupchat'
  },
  {
    title: 'We build YOUR listing',
    description: 'Others hold your listing hostage when you try to leave'
  },
  {
    title: 'Owner operated',
    description: 'Others make you work with low level staff'
  },
  {
    title: 'Commission on host payout only',
    description: 'We only take a percentage of what you receive, never on cleaning fees or Airbnb charges'
  }
];

const faqs = [
  { q: 'How much are Airbnb management fees in Toronto?', a: 'Toronto Airbnb management fees range from 18% to 30% of rental revenue depending on the company. Nurture charges a flat 15% of your host payout, which is below the market average of 20%. We only take a percentage of what you receive from Airbnb after platform fees and cleaning charges, not gross bookings.' },
  { q: 'What is the average Airbnb management fee in Toronto?', a: 'The average Airbnb management fee in Toronto is around 20% of rental revenue, with most companies charging between 18% and 25%. Premium managers charge 25% to 30%. Nurture is priced below the average at 15% because we operate lean, locally, and pass the savings on to property owners.' },
  { q: 'Do Toronto Airbnb managers charge on gross or net income?', a: 'It varies, and this is where hidden costs hide. Some companies charge a percentage of gross bookings (including cleaning fees and Airbnb service charges). Others charge on net host payout only. Nurture charges 15% on host payout only, never on cleaning fees or platform charges. Always ask potential managers to clarify the billing basis before signing.' },
  { q: 'Are there any hidden fees with Nurture?', a: 'No. The only fee is the 15% management commission. No setup fees, no onboarding fees, no markup on supplies, no minimum monthly charges, no cancellation fees. If you want to add professional photography, we coordinate that as a one-time pass-through cost (no markup).' },
  { q: 'Will I make more with short-term rental vs long-term rental?', a: 'We have never had any clients make less with short and mid-term rental vs long-term rental. Most see 30-100% increases in monthly revenue.' },
  { q: 'How long does it take to get my property listed?', a: 'The entire process of staging, professional photos, creating your listing, and onboarding takes less than a week on average. The average client sees their first booking within 1 week of getting their listing up.' },
  { q: 'Do I have to sign a lengthy contract?', a: 'No. Our service agreement allows you to cancel with just 30-day notice. No long-term contracts, no cancellation fees, no listing lock-in.' },
  { q: 'Are there any startup costs?', a: 'No. We only get paid on commission. We make money when you make money.' },
  { q: 'Who owns the listing on Airbnb?', a: 'You own the listing. If for some reason you decide to part ways, the listing is yours. We do not gatekeep anything, unlike some competitors who hold listings hostage when clients try to leave.' },
  { q: 'Why are Nurture fees lower than competitors?', a: 'Three reasons. First, we are locally owned and operated so we do not have corporate overhead. Second, we do not spend heavily on paid advertising or sales teams. Third, we believe lower fees plus better service creates long-term client relationships. Most of our new clients come from referrals, not ads.' }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Airbnb Management Fees Toronto",
  "description": "Full-service Airbnb management in Toronto at 15% of host payout. No hidden fees, no long-term contracts, no setup costs.",
  "url": "https://www.nurturestays.ca/pricing-toronto-airbnb-management",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Nurture Airbnb Property Management"
  },
  "offers": {
    "@type": "Offer",
    "priceCurrency": "CAD",
    "priceSpecification": {
      "@type": "PriceSpecification",
      "price": "15",
      "priceCurrency": "CAD",
      "description": "15% of host payout"
    }
  },
  "areaServed": [
    { "@type": "City", "name": "Toronto" },
    { "@type": "City", "name": "Mississauga" },
    { "@type": "City", "name": "Brampton" },
    { "@type": "City", "name": "Vaughan" },
    { "@type": "City", "name": "Oakville" },
    { "@type": "City", "name": "Burlington" },
    { "@type": "City", "name": "Hamilton" }
  ]
};

const pageSchema = [serviceSchema, faqSchema];
---

<Layout title="Airbnb Management Fees Toronto 2026 | Flat 15%" description="Airbnb management fees in Toronto: flat 15% commission on host payout, no hidden charges, no long contracts. Compare vs 18-25% industry average. Free estimate." schema={pageSchema}>
  <section class="hero hero-small">
    <div class="container">
      <h1>Airbnb Management Fees Toronto: Flat 15%</h1>
      <p class="hero-subtitle">Full-service Airbnb management at 15% of your host payout. No startup costs, no long contracts, no hidden fees.</p>
    </div>
  </section>

  <section class="section fees-intro-section">
    <div class="container">
      <div class="fees-intro">
        <h2>How Much Do Airbnb Management Companies Charge in Toronto?</h2>
        <p>Toronto Airbnb management fees typically fall between 18% and 25% of rental revenue, with most established companies charging 20% or more. Nurture charges a flat 15% of your host payout. That is 3 to 10 percentage points lower than competitors, and we only take a percentage of what you actually receive from Airbnb, not gross bookings.</p>

        <div class="fee-comparison-table">
          <div class="fee-row fee-header">
            <div class="fee-company">Company</div>
            <div class="fee-rate">Fee Range</div>
            <div class="fee-basis">Fee Basis</div>
          </div>
          <div class="fee-row fee-highlight">
            <div class="fee-company"><strong>Nurture</strong></div>
            <div class="fee-rate"><strong>15%</strong></div>
            <div class="fee-basis">Host payout only</div>
          </div>
          <div class="fee-row">
            <div class="fee-company">Industry average</div>
            <div class="fee-rate">18% to 25%</div>
            <div class="fee-basis">Varies (often gross)</div>
          </div>
          <div class="fee-row">
            <div class="fee-company">Premium managers</div>
            <div class="fee-rate">25% to 30%</div>
            <div class="fee-basis">Varies (often gross)</div>
          </div>
        </div>

        <p class="fee-note">The difference between net and gross billing matters. On a $1,000 booking with a $150 cleaning fee, we charge 15% of the $850 payout ($127.50). A competitor charging 15% of gross takes $150. Over 50 bookings per year, that is over $1,100 in your pocket versus theirs.</p>
      </div>
    </div>
  </section>

  <section class="section comparison-section">
    <div class="container">
      <div class="feature-comparison">
        <div class="feature-header">
          <div class="feature-label"></div>
          <div class="plan-header featured">
            <span class="plan-name">Professional</span>
            <span class="plan-rate">15%</span>
          </div>
        </div>

        <div class="feature-category">Listing & Marketing</div>
        <div class="feature-row">
          <div class="feature-label">Professional listing creation</div>
          <div class="feature-check">✓</div>
        </div>
        <div class="feature-row">
          <div class="feature-label">Multi-platform distribution</div>
          <div class="feature-check">✓</div>
        </div>
        <div class="feature-row">
          <div class="feature-label">Dynamic pricing optimization</div>
          <div class="feature-check">✓</div>
        </div>
        <div class="feature-row">
          <div class="feature-label">Listing SEO & optimization</div>
          <div class="feature-check">✓</div>
        </div>

        <div class="feature-category">Guest Management</div>
        <div class="feature-row">
          <div class="feature-label">Guest communication</div>
          <div class="feature-check">✓</div>
        </div>
        <div class="feature-row">
          <div class="feature-label">Guest vetting & screening</div>
          <div class="feature-check">✓</div>
        </div>
        <div class="feature-row">
          <div class="feature-label">Review management</div>
          <div class="feature-check">✓</div>
        </div>

        <div class="feature-category">Property Operations</div>
        <div class="feature-row">
          <div class="feature-label">Booking management</div>
          <div class="feature-check">✓</div>
        </div>
        <div class="feature-row">
          <div class="feature-label">Professional cleaning coordination</div>
          <div class="feature-check">✓</div>
        </div>
        <div class="feature-row">
          <div class="feature-label">Linen & supply restocking</div>
          <div class="feature-check">✓</div>
        </div>
        <div class="feature-row">
          <div class="feature-label">Smart lock management</div>
          <div class="feature-check">✓</div>
        </div>
        <div class="feature-row">
          <div class="feature-label">Contractor coordination</div>
          <div class="feature-check">✓</div>
        </div>

        <div class="feature-category">Support & Reporting</div>
        <div class="feature-row">
          <div class="feature-label">Monthly performance reports</div>
          <div class="feature-check">✓</div>
        </div>
        <div class="feature-row">
          <div class="feature-label">Dedicated account manager</div>
          <div class="feature-check">✓</div>
        </div>
        <div class="feature-row">
          <div class="feature-label">Insurance claim assistance</div>
          <div class="feature-check">✓</div>
        </div>

        <div class="feature-category">Additional Services</div>
        <div class="feature-row">
          <div class="feature-label">Airbnb Guest E-book</div>
          <div class="feature-check">✓</div>
        </div>
        <div class="feature-row">
          <div class="feature-label">Furnishing consulting</div>
          <div class="feature-check">✓</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section why-nurture-section">
    <div class="container">
      <div class="section-header">
        <h2>Why Nurture?</h2>
        <p>Here's why our services are different (and better)</p>
      </div>
      <div class="benefits-grid">
        {benefits.map(benefit => (
          <div class="benefit-card">
            <h4>{benefit.title}</h4>
            <p>{benefit.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section faq-section">
    <div class="container">
      <div class="section-header">
        <h2>Pricing FAQs</h2>
        <p>Common questions about our fees and billing.</p>
      </div>
      <div class="faq-grid">
        {faqs.map(faq => (
          <div class="faq-card">
            <h4>{faq.q}</h4>
            <p>{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section related-links">
    <div class="container">
      <div class="section-header">
        <h2>Learn More</h2>
        <p>Explore our services and service areas</p>
      </div>
      <div class="related-grid">
        <a href="/services" class="related-card">
          <h3>All Services</h3>
          <p>Full details on everything included in our management packages</p>
        </a>
        <a href="/emergency-airbnb-support-toronto" class="related-card">
          <h3>Emergency Support</h3>
          <p>Emergency support for urgent property issues</p>
        </a>
        <a href="/locations" class="related-card">
          <h3>Service Areas</h3>
          <p>We manage properties across the Greater Toronto Area</p>
        </a>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>Ready to Earn More While Doing Less?</h2>
        <p>Get a free property assessment and custom revenue projection.</p>
        <a href="/contact" class="btn btn-primary btn-large">Get Your Free Assessment</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero-subtitle { text-align: center; margin: 0 auto; }
  .comparison-section { background: var(--color-background); padding-top: 3rem; }

  .fees-intro-section { background: white; padding: 3rem 0; }
  .fees-intro { max-width: 900px; margin: 0 auto; text-align: center; }
  .fees-intro h2 { font-size: 2rem; margin-bottom: 1rem; color: var(--color-text); }
  .fees-intro p { color: var(--color-text-light); font-size: 1.05rem; line-height: 1.6; margin-bottom: 1.5rem; }
  .fee-comparison-table { background: var(--color-background-alt); border-radius: 12px; padding: 1.5rem; margin: 2rem 0; text-align: left; }
  .fee-row { display: grid; grid-template-columns: 2fr 1fr 2fr; gap: 1rem; padding: 0.85rem 1rem; border-bottom: 1px solid rgba(0,0,0,0.08); align-items: center; }
  .fee-row:last-child { border-bottom: none; }
  .fee-row.fee-header { font-weight: 600; color: var(--color-text); background: rgba(117, 155, 143, 0.1); border-radius: 8px; }
  .fee-row.fee-highlight { background: rgba(117, 155, 143, 0.15); border-radius: 8px; border-left: 4px solid var(--color-primary); }
  .fee-company { color: var(--color-text); }
  .fee-rate { color: var(--color-primary-dark); font-weight: 600; font-size: 1.1rem; }
  .fee-basis { color: var(--color-text-light); font-size: 0.9rem; }
  .fee-note { font-size: 0.95rem; color: var(--color-text-light); font-style: italic; margin-top: 1.5rem; }
  @media (max-width: 700px) {
    .fee-row { grid-template-columns: 1fr; gap: 0.25rem; padding: 1rem; }
    .fee-row.fee-header { display: none; }
    .fee-company::before { content: "Company: "; color: var(--color-text-light); font-weight: normal; }
    .fee-rate::before { content: "Fee: "; color: var(--color-text-light); font-weight: normal; }
    .fee-basis::before { content: "Basis: "; color: var(--color-text-light); font-weight: normal; }
  }

  .why-nurture-section { background: white; }
  .why-nurture-section .section-header { text-align: center; margin-bottom: 3rem; }
  .why-nurture-section .section-header h2 { font-size: 2rem; margin-bottom: 0.5rem; }
  .why-nurture-section .section-header p { color: var(--color-text-light); font-size: 1.1rem; }
  .benefits-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; max-width: 1000px; margin: 0 auto; }
  .benefit-card { background: var(--color-background-alt); border-radius: 12px; padding: 1.5rem; border-left: 4px solid var(--color-primary); }
  .benefit-card h4 { margin: 0 0 0.5rem; font-size: 1.05rem; color: var(--color-text); }
  .benefit-card p { margin: 0; color: var(--color-text-light); font-size: 0.95rem; }
  @media (max-width: 968px) { .benefits-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .benefits-grid { grid-template-columns: 1fr; } }
  .case-study-section { background: var(--color-primary-dark); color: white; }
  .case-study-section .section-header h2 { color: white; }
  .case-study-section .section-header p { color: rgba(255,255,255,0.8); }
  .case-study-card { max-width: 900px; margin: 0 auto; }
  .comparison-container { display: grid; grid-template-columns: 1fr auto 1fr; gap: 2rem; align-items: center; background: rgba(255,255,255,0.1); backdrop-filter: blur(10px); padding: 2rem; border-radius: 16px; }
  .before-card, .after-card { padding: 1.5rem; }
  .before-card h3, .after-card h3 { font-size: 1.25rem; margin-bottom: 1.5rem; color: rgba(255,255,255,0.9); }
  .financial-line { display: flex; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid rgba(255,255,255,0.1); font-size: 1rem; }
  .financial-line:last-child { border-bottom: none; }
  .financial-line.total { padding-top: 1rem; font-weight: 700; font-size: 1.25rem; }
  .financial-line .negative { color: #FFB3B3; }
  .financial-line .positive { color: #B3FFB3; }
  .arrow { font-size: 2.5rem; color: var(--color-accent); }
  .increase-badge { text-align: center; margin-top: 2rem; font-size: 1.5rem; font-weight: 700; color: var(--color-accent); }
  .faq-section { background: white; }
  .faq-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem; }
  .faq-card { padding: 1.5rem; background: var(--color-background-alt); border-radius: 12px; }
  .faq-card h4 { margin: 0 0 0.75rem; font-size: 1.1rem; }
  .faq-card p { color: var(--color-text-light); margin: 0; font-size: 0.95rem; }
  .comparison-section { background: var(--color-background-alt); }
  .feature-comparison { max-width: 800px; margin: 0 auto; background: white; border-radius: 16px; overflow: hidden; box-shadow: var(--shadow-md); }
  .feature-header { display: grid; grid-template-columns: 2fr 1fr; background: var(--color-dark); color: white; }
  .plan-header { text-align: center; padding: 1.5rem 1rem; }
  .plan-header.featured { background: var(--color-primary); }
  .plan-name { display: block; font-weight: 600; font-size: 1.1rem; margin-bottom: 0.25rem; }
  .plan-rate { font-size: 1.75rem; font-weight: 700; }
  .feature-category { background: var(--color-background-alt); padding: 0.75rem 1.5rem; font-weight: 600; font-size: 0.9rem; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
  .feature-row { display: grid; grid-template-columns: 2fr 1fr; border-bottom: 1px solid var(--color-border); }
  .feature-row:last-child { border-bottom: none; }
  .feature-label { padding: 1rem 1.5rem; font-size: 0.95rem; display: flex; align-items: center; }
  .feature-check { padding: 1rem; text-align: center; font-size: 1.25rem; color: var(--color-primary); font-weight: 600; display: flex; align-items: center; justify-content: center; }
  .feature-check.empty { color: #ccc; font-weight: 400; }
  .cta-section { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%); padding: 5rem 0; text-align: center; color: white; }
  .cta-content h2 { margin-bottom: 1rem; }
  .cta-content p { font-size: 1.25rem; opacity: 0.9; margin-bottom: 2rem; }
  .cta-section .btn { background: white; color: var(--color-primary); }
  .related-links { background: var(--color-background-alt); }
  .related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
  .related-card { display: block; padding: 2rem; background: white; border-radius: 16px; text-decoration: none; transition: all 0.3s ease; border: 2px solid transparent; }
  .related-card:hover { border-color: var(--color-primary); transform: translateY(-4px); box-shadow: var(--shadow-lg); }
  .related-card h3 { color: var(--color-text); margin: 0 0 0.5rem; }
  .related-card p { color: var(--color-text-light); margin: 0; font-size: 0.95rem; }
  @media (max-width: 968px) { .faq-grid { grid-template-columns: 1fr; } .comparison-container { grid-template-columns: 1fr; gap: 1rem; } .arrow { transform: rotate(90deg); } .related-grid { grid-template-columns: 1fr; } }
  @media (max-width: 600px) { .feature-header, .feature-row { grid-template-columns: 1.5fr 1fr; } .feature-label { padding: 0.75rem 1rem; font-size: 0.85rem; } .feature-check { padding: 0.75rem 0.5rem; font-size: 1rem; } .plan-name { font-size: 0.9rem; } .plan-rate { font-size: 1.25rem; } .feature-category { padding: 0.5rem 1rem; font-size: 0.8rem; } }
</style>
